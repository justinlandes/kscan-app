# ─────────────────────────────────────────────────────────────────────────────
# K Scan AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider Keys (server-side only — never expose to the app bundle) ──────

# Google Gemini API key (used when USE_OPENROUTER=false)
GEMINI_API_KEY=

# OpenRouter API key (used when USE_OPENROUTER=true)
OPENROUTER_API_KEY=

# OpenRouter model string — default is meta-llama/llama-4-scout
OPENROUTER_MODEL=meta-llama/llama-4-scout

# Set to "true" to route analysis through OpenRouter instead of Gemini directly
USE_OPENROUTER=true

# ── Server Config ─────────────────────────────────────────────────────────────

# Port the server listens on.
# - Local dev: 3001 (default, no need to set)
# - Hosted (Render/Railway): injected automatically by the platform — do NOT set here
PORT=3001

# CORS origin restriction.
# - Local dev: * (open)
# - Production: set to your app's actual origin if you have a web frontend.
#   For a pure native app with no web frontend, * is acceptable.
CORS_ORIGIN=*

# Verbose product-matching log. Set to "false" in production to reduce log noise.
KSCAN_LOG_MATCH=true

# ── Expo App Config (EXPO_PUBLIC_ prefix exposes variable to the app bundle) ──
#
# Pick the line that matches your current dev environment and uncomment it.
# Only ONE should be active at a time.

# iOS Simulator (shares host network — localhost resolves correctly):
# EXPO_PUBLIC_API_URL=http://localhost:3001

# Android Emulator (10.0.2.2 is the emulator's loopback alias for the host):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001

# Physical Android/iOS device on the same Wi-Fi (replace with your machine's LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.X:3001

# Hosted beta backend on Render (replace with your actual service URL):
# EXPO_PUBLIC_API_URL=https://kscan-api.onrender.com

# ── Supabase (account-level privacy sync — requires real Supabase Auth) ───────
#
# These two variables are required for the Supabase project to be reachable.
# The app uses @supabase/supabase-js with AsyncStorage session persistence.
# Account-level privacy preferences are persisted using the authenticated
# session token — NOT a manually pasted access token.
#
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
#
# ── DEV-ONLY: Manual access token override (internal testing only) ───────────
#
# EXPO_PUBLIC_SUPABASE_ACCESS_TOKEN is a development bridge for testing
# privacy persistence without completing a real sign-in flow.
# It is NEVER the normal production path. If a real Supabase Auth session
# exists, it always takes precedence over this value.
#
# Remove or leave blank for normal operation.
# If set, a console warning is shown: "DEV TOKEN IN USE".
#
# EXPO_PUBLIC_SUPABASE_ACCESS_TOKEN=eyJ...
