# ─────────────────────────────────────────────────────────────────────────────
# K Scan AI — Local Development Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values that match your setup.
# .env.local is git-ignored; never commit real credentials.
#
# EXPO_PUBLIC_ variables are baked into the app bundle at build time.
# Only use this prefix for values that are safe to be public (non-secret).
# Never put API keys, service secrets, or tokens in EXPO_PUBLIC_ variables.
# ─────────────────────────────────────────────────────────────────────────────


# ── Backend URL (pick ONE and uncomment it) ───────────────────────────────────
#
# iOS Simulator — localhost resolves to the host machine directly:
# EXPO_PUBLIC_API_URL=http://localhost:3001
#
# Android Emulator — 10.0.2.2 is the emulator loopback alias for the host:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3001
#
# Physical device on the same Wi-Fi (replace X.X.X.X with your machine's LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.X.X:3001
#
# Hosted Render backend (works from any device / EAS cloud build):
# EXPO_PUBLIC_API_URL=https://kscan-app-1.onrender.com
#
EXPO_PUBLIC_API_URL=https://kscan-app-1.onrender.com


# ── Supabase (required for auth / privacy sync) ───────────────────────────────
# These are your project's public URL and anonymous key — safe to expose.
# Find them in Supabase → Project Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here


# ── E2E / Simulator mock scan (optional) ─────────────────────────────────────
# Set to "true" to bypass the real camera and backend during Maestro tests or
# iOS Simulator runs. Enables the full state-machine flow without hardware.
# NEVER set this to "true" in a production build.
# EXPO_PUBLIC_E2E_MOCK_SCAN=false


# ── AI Provider Keys (server-side only — never use EXPO_PUBLIC_ here) ─────────
# Only needed when running server.js locally; the hosted Render backend has its
# own keys configured as server environment variables.
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-4-scout
# USE_OPENROUTER=true


# ── Local server config ───────────────────────────────────────────────────────
# PORT=3001
# CORS_ORIGIN=*
# KSCAN_LOG_MATCH=true
