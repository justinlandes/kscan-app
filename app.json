{
  "expo": {
    "name": "K Scan",
    "slug": "kscan",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "scheme": "kscan",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "K Scan uses your camera to scan fashion items and find visually similar products."
        }
      ],
      "expo-router"
    ],
    "android": {
      "package": "com.kscanai.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0a2e"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "kscan"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.kscanai.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "K Scan uses your camera to scan fashion items and find visually similar products."
      }
    },
    "extra": {
      "eas": {
        "projectId": "a075728d-bd77-446f-843d-0f63fd54cc2e"
      }
    }
  }
}
